<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Prerendered SEO pages — unique HTML per route for Search Console
  RewriteRule ^(about|projects|services|faqs|contact|login)/?$ $1/index.html [L]

  # Serve existing files/folders directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>
